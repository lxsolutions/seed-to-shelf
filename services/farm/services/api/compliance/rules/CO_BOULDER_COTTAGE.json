










{
  "jurisdiction_code": "CO_BOULDER_COTTAGE",
  "name": "Boulder County Cottage Foods Program",
  "description": "Cottage foods regulations for Boulder County, CO",
  "rules": [
    {
      "rule_id": "HOME_KITCHEN_ONLY",
      "type": "KITCHEN_TYPE",
      "allowed_types": ["HOME"],
      "message": "Only HOME kitchens are allowed under the Cottage Foods program."
    },
    {
      "rule_id": "PERMIT_REQUIRED",
      "type": "PERMIT",
      "required_permits": ["COTTAGE_FOODS"],
      "message": "A valid Cottage Foods permit is required for home kitchen operations."
    },
    {
      "rule_id": "COUNTY_BOUNDARY",
      "type": "GEOGRAPHIC_RESTRICTION",
      "boundary_type": "county",
      "allowed_counties": ["Boulder"],
      "message": "Sales and deliveries are restricted to Boulder County."
    },
    {
      "rule_id": "FOOD_TYPES_RESTRICTED",
      "type": "FOOD_RESTRICTION",
      "prohibited_food_types": ["TCS", "hot_meals"],
      "allowed_food_types": [
        "baked_goods_without_cream_filling_or_frosting",
        "candies_and_chocolates",
        "cookies_and_brownies",
        "dry_rub_mixes",
        "fruit_pies_and_jams"
      ],
      "message": "Only non-TCS, shelf-stable foods are allowed under Cottage Foods regulations."
    },
    {
      "rule_id": "LABELING_REQUIRED",
      "type": "LABELING",
      "required_label_elements": [
        {"element": "name", "description": "Product name"},
        {"element": "address", "description": "Home kitchen address with 'Made in a home kitchen' notation"},
        {"element": "ingredients", "description": "Complete ingredient list"},
        {"element": "allergens", "description": "Allergen warnings"},
        {"element": "net_weight", "description": "Net weight of product"}
      ],
      "message": "Proper labeling is required for all cottage food products."
    }
  ],
  "permit_requirements": {
    "COTTAGE_FOODS": {
      "required_docs": [
        {"type": "health_permit", "description": "Boulder County Health Department permit"},
        {"type": "food_safety_certificate", "description": "Approved food safety certification"}
      ]
    }
  },
  "links": {
    "regulatory_info": "https://www.bouldercounty.org/cottage-foods",
    "application_form": "https://www.bouldercounty.org/forms/cottage-foods-application"
  }
}










